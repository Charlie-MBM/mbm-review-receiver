# Copy this file to `.env` and fill in real values.
# .env is gitignored — never commit real keys.

# ===== Hint Health =====
# HINT_ENV controls the API base URL.
#   sandbox    → https://api.sandbox.hint.com (default, for testing)
#   production → https://api.hint.com
HINT_ENV=production

# Practices API key. Get from: Hint admin → API access.
# Used for patient lookups and listing recent events.
HINT_API_KEY=replace_me

# Partner API key. Get from: https://app.hint.com/partner/api_keys
# Only used by the (unused) Flask webhook signature verifier.
# Optional in the poller path — leave blank if not registered as a Hint partner.
HINT_PARTNER_API_KEY=

# ===== Spruce Health =====
# API access is gated by Team Spruce (Tasks #36 + #40).
# Once enabled: Spruce dashboard → Settings → Integrations & API → API Access
SPRUCE_API_KEY=replace_me

# Spruce internal endpoint ID for outbound SMS. Find via:
#   GET https://api.sprucehealth.com/v1/internalendpoints
# Pick the channel of type "phone". This is the (360) 295-9241 line.
SPRUCE_INTERNAL_ENDPOINT_ID=replace_me

# ===== Email (optional — the script sends SMS-first, email is backup) =====
# Resend API key for the patient review-request email path.
# Leave blank to skip email sends and only do SMS.
RESEND_API_KEY=
FROM_EMAIL=Mt. Baker Medical <care@mtbakermedical.com>

# ===== Review URL =====
# The /review landing page on the live site.
REVIEW_BASE_URL=https://mtbakermedical.com

# ===== Behavior =====
# DRY_RUN=true → log what would have been sent, send nothing. SAFE DEFAULT for first run.
# Set to false only after dry-run looks correct.
DRY_RUN=true

# ===== Logging =====
# PORT only matters if you start the Flask server (you shouldn't — use the CLI).
PORT=5000
