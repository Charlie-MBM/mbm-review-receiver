# Copy this file to `.env` and fill in real values.
# .env is gitignored — never commit real keys.

# ===== Hint Health =====
# HINT_ENV controls the API base URL.
#   sandbox    → https://api.sandbox.hint.com (default, for testing)
#   production → https://api.hint.com
HINT_ENV=production

# Practices API key. Get from: Hint admin → API access.
# Used for patient lookups and listing recent events.
HINT_API_KEY=replace_me

# Partner API key. Get from: https://app.hint.com/partner/api_keys
# Only used by the (unused) Flask webhook signature verifier.
# Optional in the poller path — leave blank if not registered as a Hint partner.
HINT_PARTNER_API_KEY=

# ===== Spruce Health =====
# API access is gated by Team Spruce (Tasks #36 + #40).
# Once enabled: Spruce dashboard → Settings → Integrations & API → API Access
SPRUCE_API_KEY=replace_me

# Spruce internal endpoint ID for outbound SMS. Find via:
#   GET https://api.sprucehealth.com/v1/internalendpoints
# Pick the channel of type "phone". This is the (360) 295-9241 line.
SPRUCE_INTERNAL_ENDPOINT_ID=replace_me

# ===== Email (optional — the script sends SMS-first, email is backup) =====
# Resend API key for the patient review-request email path.
# Leave blank to skip email sends and only do SMS.
RESEND_API_KEY=
FROM_EMAIL=Mt. Baker Medical <care@mtbakermedical.com>

# ===== Review URL =====
# The /review landing page on the live site (Cloudflare Worker).
# Also the base URL for the /api/review-clicked click-tracker endpoint.
REVIEW_BASE_URL=https://mtbakermedical.com

# ===== Click-tracker (Cloudflare Worker /api/review-clicked) =====
# Shared secret between this poller (GET reader) and the Worker (issued
# at request time as `Authorization: Bearer <token>`). Any random 32+ char
# string. Must match the Worker secret set in Cloudflare Dashboard:
#   Workers → mtbakermedical → Settings → Variables → "Add variable" →
#   set TYPE to "Secret" → name=CLICK_TRACKER_TOKEN → value=<same string>.
# If unset, the poller skips the click-check (won't suppress already-clicked
# patients; the 3-cap still applies as fallback).
CLICK_TRACKER_TOKEN=

# ===== Walk-In / IV review branch =====
# Feature flag for the Walk-In / IV (Service-Only plans) review branch in
# send_review_requests.py. Default false = branch is a no-op. Enable only
# after the walk-in SMS consent basis (TCPA) is cleared. See
# WALKIN_REVIEW_WIRING_DESIGN.md.
WALKIN_REVIEW_ENABLED=false

# ===== Behavior =====
# DRY_RUN=true → log what would have been sent, send nothing. SAFE DEFAULT for first run.
# Set to false only after dry-run looks correct.
DRY_RUN=true

# ===== Logging =====
# PORT only matters if you start the Flask server (you shouldn't — use the CLI).
PORT=5000

# ===== GA4 (the digest's Phone/Booking click lines) =====
# GA4_PROPERTY_ID: property the website reports to. Unset = the digest silently ships
# WITHOUT the click lines, so don't leave it blank and assume it's fine.
GA4_PROPERTY_ID=513547844
#
# GOOGLE_APPLICATION_CREDENTIALS: absolute path to a GCP SERVICE-ACCOUNT JSON key that has
# Viewer on the GA4 property. This is REQUIRED. If it is unset, google-auth silently falls
# back to whoever ran `gcloud auth application-default login` on this laptop, and that path
# fails two ways: (a) those creds lack the analytics.readonly scope -> 403
# ACCESS_TOKEN_SCOPE_INSUFFICIENT, and (b) they EXPIRE, so an unattended scheduled task
# loses GA4 with no alarm (this is exactly what happened 2026-07). Google is additionally
# blocking analytics.readonly for the default ADC client id, so user creds are a dead end.
# Use a service account. Keep the JSON file OUTSIDE this repo so it can never be committed.
GOOGLE_APPLICATION_CREDENTIALS=C:\Users\charl\secrets\mbm-ga4-reader.json
