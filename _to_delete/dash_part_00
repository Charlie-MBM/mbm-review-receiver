  .chip:hover{border-color:#c9d3cb}
  .chip i{width:8px;height:8px;border-radius:50%;display:inline-block;box-shadow:0 0 0 3px rgba(0,0,0,.035)}
  .chip.fresh i{background:var(--good);box-shadow:0 0 0 3px rgba(47,125,80,.14)}
  .chip.aging i{background:#c9a227;box-shadow:0 0 0 3px rgba(201,162,39,.16)}
  .chip.stale i{background:var(--bad);box-shadow:0 0 0 3px rgba(180,69,47,.15)}
