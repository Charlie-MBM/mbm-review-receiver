    <div class="tabs" id="entryTabs">
      <button class="tab active" data-tab="members">Members</button>
      <button class="tab" data-tab="ads">Ad numbers</button>
      <button class="tab" data-tab="funnel">Funnel overrides</button>
      <button class="tab" data-tab="settings">Settings</button>
    </div>
    <div id="entryBody"></div>
  </div>

  <div class="foot" id="foot"></div>
