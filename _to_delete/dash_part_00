  .card .v small{font-size:14px;color:var(--muted);font-weight:500}
  .card.stale{background:repeating-linear-gradient(135deg,#fff,#fff 9px,#f3f3ef 9px,#f3f3ef 12px)}
  .asof{font-family:var(--label);font-size:10px;color:var(--stale);margin-top:7px}
  .smalltag{font-family:var(--label);font-size:10px;font-weight:600;color:var(--muted);background:#eef1ec;border-radius:5px;padding:1px 6px;display:inline-block}
