  .banner.warn{background:#fbf3e6;color:var(--warn);border:1px solid #e7d3aa}
  .panel{background:var(--card);border:1px solid var(--line);border-radius:14px;padding:18px;margin-top:14px;box-shadow:var(--shadow-1)}
  .grid2{display:grid;grid-template-columns:1fr 1fr;gap:14px}
  .grid3{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
  /* funnel */
  .funnel{display:flex;flex-direction:column;gap:0}
  .fstage{display:flex;align-items:center;gap:12px;padding:2px 0}
  .fbar-wrap{flex:1;display:flex;align-items:center;gap:8px}
  .fnum-out{font-family:var(--label);font-size:12.5px;font-weight:600;color:var(--ink);white-space:nowrap}
