  <div class="cards" id="gbpCards"></div>
  <div class="panel" style="margin-top:14px">
    <div class="small" style="font-weight:600;font-size:13px;color:var(--forest);margin-bottom:4px">Local pack tracker <span class="small" style="font-weight:400">— MBM position per pack, baseline (pre-change) vs latest re-measure</span></div>
    <div id="gbpPacks"></div>
    <div class="small" id="gbpNote" style="margin-top:10px;line-height:1.8"></div>
  </div>

  <!-- SEO -->
  <h2 class="sec">Website &amp; SEO<span class="rule"></span><span class="pill" id="seoLiveState">weekly snapshot</span></h2>
  <p class="sec-note">Google Search Console finalizes 2–3 days late — the current month is always partial. Recent dips are incomplete data, not real drops. <span class="small" id="seoSyncNote"></span></p>
  <div id="seoBody">
    <div class="cards" id="seoKpis" style="margin-bottom:14px"></div>
    <div class="grid2">
      <div class="panel"><div class="small" style="margin-bottom:6px">GSC clicks <span class="small" style="font-weight:400">— dashed = current month projected</span></div><div class="chartbox" style="height:86px"><canvas id="chGscClicks"></canvas></div><div class="small" style="margin:10px 0 6px">GSC impressions</div><div class="chartbox" style="height:86px"><canvas id="chGscImpr"></canvas></div></div>
      <div class="panel"><div class="small" style="margin-bottom:6px">Average position (lower is better)</div><div class="chartbox"><canvas id="chPos"></canvas></div></div>
    </div>
    <div class="panel" style="margin-top:14px;background:#f7faf8"><div class="small" id="gscProjNote" style="line-height:1.85"></div></div>
    <div class="panel" style="margin-top:14px">
      <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px;margin-bottom:10px">
        <div class="small" style="font-weight:600;font-size:13px;color:var(--forest)">Tracked keyword rankings <span id="kwCount" class="small" style="font-weight:400"></span></div>
        <div class="tabs" id="kwFilters" style="margin-bottom:0"></div>
