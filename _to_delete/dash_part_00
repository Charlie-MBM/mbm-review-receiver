<script>
"use strict";
/* ============================================================
   Mt. Baker Medical — Performance Dashboard (rebuilt 2026-07-16)
   NORTH STAR: active Concierge members vs 300 goal.

   CONTRACT FOR REFRESH TASKS (read this before editing):
