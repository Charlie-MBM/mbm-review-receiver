  .brand h1{font-family:var(--display);font-weight:600;color:var(--forest);margin:0;font-size:30px;letter-spacing:.2px;line-height:1.05}
  .brand .tag{font-family:var(--display);font-style:italic;color:var(--sage);font-size:18px;margin-top:2px}
  .brand .sub{font-family:var(--label);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);margin-top:6px}
