  .flabel{font-family:var(--label);font-size:12px;color:var(--muted);width:170px;text-align:right}
  .fconv{font-family:var(--label);font-size:11px;color:var(--sage);text-align:center;padding:2px 0 2px 182px}
  .fbar-split{padding:0;background:none;position:relative;overflow:hidden}
  .fbar-split .fnum{position:absolute;left:12px;top:0;height:100%;display:flex;align-items:center;color:#fff;font-weight:600;z-index:1;text-shadow:0 1px 2px rgba(0,0,0,.28)}
  .fbar-split>span:not(.fnum){display:block;height:100%}
  .fbar-empty{background:#e3e7e1;color:var(--muted)}
  .fbar-empty .fsub{font-weight:400;font-style:italic;margin-left:4px}
  .mixlegend{display:flex;flex-wrap:wrap;gap:8px 14px;margin-top:8px;font-family:var(--label);font-size:11px;color:var(--muted)}
  .mixlegend i{display:inline-block;width:9px;height:9px;border-radius:2px;margin-right:4px;vertical-align:middle}
  /* tables */
  table{border-collapse:collapse;width:100%;font-family:var(--label);font-size:13px}
  th,td{text-align:left;padding:8px 10px;border-bottom:1px solid var(--line)}
  th{font-size:11px;letter-spacing:.05em;text-transform:uppercase;color:var(--muted);font-weight:600}
  td.num,th.num{text-align:right;font-variant-numeric:tabular-nums}
  tr:hover td{background:#f6f8f5}
  .btn{font-family:var(--label);font-size:13px;font-weight:600;border:1px solid var(--forest);background:var(--forest);color:#fff;border-radius:8px;padding:8px 14px;cursor:pointer}
  .btn:hover{background:#0e3018}
  .btn.ghost{background:#fff;color:var(--forest)}
  .btn.sm{padding:4px 9px;font-size:12px}
  .btn.danger{border-color:var(--bad);color:var(--bad);background:#fff}
  .formgrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:10px;align-items:end}
  .field{display:flex;flex-direction:column;gap:4px}
  .field label{font-family:var(--label);font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.05em}
  .tabs{display:flex;gap:6px;margin-bottom:10px;flex-wrap:wrap}
  .tab{font-family:var(--label);font-size:13px;font-weight:600;border:1px solid var(--line);background:#fff;color:var(--muted);border-radius:999px;padding:6px 14px;cursor:pointer}
  .tab.active{background:var(--lightsage);color:var(--forest);border-color:var(--lightsage)}
  .chartbox{position:relative;height:190px}
  .small{font-family:var(--label);font-size:11px;color:var(--muted)}
  .pill{font-family:var(--label);font-size:11px;font-weight:600;padding:2px 8px;border-radius:999px;background:#eef1ec;color:var(--sage)}
  .foot{font-family:var(--label);font-size:11px;color:var(--muted);margin-top:30px;border-top:1px solid var(--line);padding-top:14px;line-height:1.8}
  @media(max-width:820px){.cards{grid-template-columns:repeat(2,1fr)}.grid2,.grid3{grid-template-columns:1fr}.flabel{width:96px}.fconv{padding-left:108px}}
  #kwTableWrap table{font-size:12.5px}
  #kwTableWrap th{position:sticky;top:0;background:#f3f6f2;cursor:pointer;white-space:nowrap;z-index:1}
  #kwTableWrap th:hover{color:var(--forest)}
  #kwTableWrap td{padding:6px 10px}
  #kwTableWrap tr.t1 td:first-child{box-shadow:inset 3px 0 0 var(--sage)}
  .pospill{display:inline-block;min-width:30px;text-align:center;font-weight:700;border-radius:5px;padding:1px 6px;font-variant-numeric:tabular-nums}
  .pos-top3{background:#dff0e4;color:#1f6b3c}
  .pos-top10{background:#eef4ef;color:var(--sage)}
  .pos-low{background:#f1efe9;color:var(--muted)}
  .pos-none{color:#b9b9b9}
  .tierbadge{display:inline-block;font-size:10px;font-weight:700;border-radius:4px;padding:1px 5px}
  .tb1{background:#dff0e4;color:#1f6b3c}.tb2{background:#eef1ec;color:var(--sage)}.tb3{background:#f1efe9;color:var(--muted)}
  .dlt-up{color:var(--good);font-weight:600}.dlt-dn{color:var(--bad);font-weight:600}.dlt-flat{color:#c2c2c2}
  .rate{font-family:var(--label);font-size:11px;color:var(--muted)}
  .rate b{color:var(--forest)}
</style>
</head>
