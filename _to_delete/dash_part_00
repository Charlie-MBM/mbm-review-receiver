function saveCfg(patch){ store.set("config", Object.assign(cfg(), patch)); }

/* Seed baked data on version bump. Preserves manual entries (active members,
   Meta/Nextdoor weekly pulls for other periods, funnel overrides for past months). */
function seedRealData(){
  if(store.get("data_version")===DATA_VERSION) return;
  const per=SNAPSHOT.period;
  store.set("funnel:"+per, {site_visits:SNAPSHOT.funnel_mtd.visits, inq_booking:SNAPSHOT.funnel_mtd.taps_booking,
    inq_phone:SNAPSHOT.funnel_mtd.taps_phone, handoffs:SNAPSHOT.funnel_mtd.handoffs,
    consults:SNAPSHOT.consults.scheduled_mtd, new_members:SNAPSHOT.members.new_paid.concierge+SNAPSHOT.members.new_paid.so});
  store.set("funnel_src:"+per, {visits:SNAPSHOT.funnel_mtd.visits_src, inquiries:SNAPSHOT.funnel_mtd.taps_src});
  store.set("ads:"+per+":google", {spend:SNAPSHOT.gads.mtd.spend, impressions:SNAPSHOT.gads.mtd.impressions, clicks:SNAPSHOT.gads.mtd.clicks, conversions:SNAPSHOT.gads.mtd.conv_ga4_all});
  store.set("ads:"+per+":meta", {spend:SNAPSHOT.meta_ads.spend, impressions:SNAPSHOT.meta_ads.impressions, clicks:SNAPSHOT.meta_ads.clicks, conversions:SNAPSHOT.meta_ads.lpv});
  store.set("ads:"+per+":nextdoor", {spend:SNAPSHOT.nextdoor_ads.spend, impressions:SNAPSHOT.nextdoor_ads.impressions, clicks:SNAPSHOT.nextdoor_ads.clicks, conversions:0});
  store.set("members_split:"+per, SNAPSHOT.members.new_paid);
  store.set("members_source:"+per, SNAPSHOT.members.source_mix);
  store.set("consults_hint:"+per, SNAPSHOT.consults);
  store.set("members_pending:"+per, SNAPSHOT.members.pending);
  store.del("kw_live"); store.del("kw_live_date");
  store.set("data_version", DATA_VERSION);
}

/* ---------- period helpers ---------- */
function pad(n){return String(n).padStart(2,"0");}
function curPeriod(){ const d=new Date(); return d.getFullYear()+"-"+pad(d.getMonth()+1); }
function recentPeriods(n){ const out=[]; const d=new Date();
  for(let i=0;i<n;i++){ const t=new Date(d.getFullYear(), d.getMonth()-i, 1); out.push(t.getFullYear()+"-"+pad(t.getMonth()+1)); } return out; }
function selectedPeriod(){ const el=document.getElementById("periodSel"); return el&&el.value?el.value:curPeriod(); }
function periodRange(period){
  const p=(period||"").split("-"); const y=+p[0], m=+p[1];
  const M=["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
  if(!y||!m) return "";
  const now=new Date();
  if(y===now.getFullYear() && (m===now.getMonth()+1)) return M[m-1]+" 1–"+now.getDate()+", "+y+" · month-to-date";
  return M[m-1]+" "+y+" · full month";
}
function setRangePill(id, period){ const el=document.getElementById(id); if(el) el.textContent=periodRange(period); }

/* ---------- accessors ---------- */
function getAds(period){ const o={}; PLATFORMS.forEach(p=>{ o[p]=Object.assign({spend:0,impressions:0,clicks:0,conversions:0}, store.get("ads:"+period+":"+p, {})); }); return o; }
function getFunnel(period){ return Object.assign({site_visits:0,inq_booking:0,inq_phone:0,handoffs:0,consults:0,new_members:0}, store.get("funnel:"+period, {})); }
function getActive(){
  // Prefer the FEED-baked active counts (SNAPSHOT.members.active, written by the
  // daily/weekly refresh from members_feed.json.active_members) over manual entry,
  // unless the manual entry is strictly newer (ISO-string compare).
  const ks=store.keys("active:").sort();
  const manual=ks.length?Object.assign({period:ks[ks.length-1].split(":")[1]}, store.get(ks[ks.length-1],{})):null;
  const feed=SNAPSHOT.members.active;
  if(feed && feed.concierge!=null){
    if(!(manual && manual.as_of && feed.as_of && manual.as_of>feed.as_of)) return feed;
  }
  return manual;
}
function paidTotals(period){ const a=getAds(period); let spend=0; PLATFORMS.forEach(p=>{spend+=+a[p].spend||0;}); return {spend}; }
/* Spend actually attributable to the selected month. Meta is excluded for the
   current period: its manual pull is a trailing-30 window (and the campaign is
   frozen "Not delivering"), so mixing it into an MTD ratio would lie by window. */
function spendMTD(period){ const a=getAds(period);
  if(period===curPeriod()) return {spend:(+a.google.spend||0)+(+a.nextdoor.spend||0), note:"Google + Nextdoor MTD spend; Meta excluded (trailing-30 window, not delivering)"};
  return {spend:(+a.google.spend||0)+(+a.meta.spend||0)+(+a.nextdoor.spend||0), note:"all paid spend for the month"};
}

/* ---------- formatting & stats ---------- */
const fmtN = n => (n==null||isNaN(n))?"—":Math.round(n).toLocaleString();
const fmtUSD = n => (n==null||isNaN(n))?"—":"$"+(Math.round(n*100)/100).toLocaleString(undefined,{minimumFractionDigits:0,maximumFractionDigits:2});
const fmtPct = n => (n==null||isNaN(n))?"—":(Math.round(n*10)/10)+"%";
const fmtPos = n => (n==null||isNaN(n))?"—":(Math.round(n*10)/10);
function escapeHtml(s){ return String(s==null?"":s).replace(/[&<>"]/g,c=>({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;"}[c])); }
/* Wilson 95% interval for k successes of n — the honest way to show a small-n rate */
function wilson(k,n){
  if(!(n>0)) return null;
  const z=1.96, p=k/n, d=1+z*z/n;
  const c=(p+z*z/(2*n))/d, h=(z*Math.sqrt(p*(1-p)/n+z*z/(4*n*n)))/d;
  return {p:p*100, lo:Math.max(0,(c-h))*100, hi:Math.min(1,(c+h))*100};
}
function rateHTML(k,n,label){
  const w=wilson(k,n); if(!w) return '';
  return '<span class="rate"><b>'+Math.round(w.p)+'%</b> ('+Math.round(w.lo)+'–'+Math.round(w.hi)+'%) '+label+'</span>';
}
/* Trend arrows are deliberately NOT drawn on counts below a ~20/period baseline —
   at MBM's volume a ±1 member is a 12–33% "swing" that is pure Poisson noise. */
function smallN(){ return '<div class="small" style="margin-top:6px;color:var(--stale)">small numbers — judge the 3-month direction, not month-over-month</div>'; }

/* ---------- freshness & anomalies ---------- */
function srcState(k){
  const s=SNAPSHOT.sources[k]; if(!s) return null;
  const live=store.get("src_asof:"+k, null);   // live-refresh success updates this
  const asof=live||s.as_of;
  if(!asof){ // source declared but never pulled (e.g. QB/Kit awaiting connector auth)
    return {key:k, label:s.label, asof:null, ageH:Infinity, cls:"stale", err:store.get("src_err:"+k,null), how:s.how, unwired:true};
  }
  const err=store.get("src_err:"+k, null);
  const ageH=(Date.now()-new Date(asof).getTime())/3600000;
  let cls="fresh";
  if(ageH>s.cadence_h*2) cls="stale"; else if(ageH>s.cadence_h) cls="aging";
  if(k==="meta"||k==="nextdoor"||k==="ahrefs") cls=(ageH>s.cadence_h*2)?"stale":"manual";
  return {key:k, label:s.label, asof, ageH, cls, err, how:s.how};
}
function fmtAge(h){ if(!isFinite(h)) return "never"; if(h<1) return Math.round(h*60)+"m ago"; if(h<48) return Math.round(h)+"h ago"; return Math.round(h/24)+"d ago"; }
function renderStatus(){
  const chips=Object.keys(SNAPSHOT.sources).map(k=>{
    const s=srcState(k);
    const t=escapeHtml(s.label)+" · "+fmtAge(s.ageH)+(s.err?(" · last refresh failed: "+escapeHtml(s.err)):"")+" · "+escapeHtml(s.how);
    return '<span class="chip '+s.cls+'" title="'+t+'"><i></i>'+escapeHtml(s.label)+' <span style="font-weight:400">'+fmtAge(s.ageH)+'</span>'+(s.err?' ⚠':'')+'</span>';
  }).join("");
  document.getElementById("srcChips").innerHTML=chips;

  const alerts=[]; const D=SNAPSHOT.daily;
  /* 1. Ads primary-conversion blackout: taps flowing but Conversions column silent.
        This exact detector would have fired on Jul 3 for the incident fixed today. */
  const look=7;
  const tapsW=D.taps.slice(-look).reduce((a,b)=>a+b,0);
  const convW=D.ads_conv_primary.slice(-look).reduce((a,b)=>a+b,0);
  const clicksW=D.ads_clicks.slice(-look).reduce((a,b)=>a+b,0);
  if(convW===0 && tapsW>=10 && clicksW>=30){
    alerts.push('<div class="alert red">🚨<div><b>Google Ads "Conversions" column has been silent for 7+ days</b> while the site logged '+tapsW+' booking/phone taps and Ads spent money on '+clicksW+' clicks. '+escapeHtml(SNAPSHOT.gads.incident.what)+'<br><b>Status:</b> '+escapeHtml(SNAPSHOT.gads.incident.fixed)+' If this alert is still red after Jul 19, the fix didn\'t hold — escalate.</div></div>');
  }
  /* 2. Site tap tracking quiet: ≥2 consecutive zero-tap days is p<1% at ~4 taps/day */
  let zrun=0; for(let i=D.taps.length-1;i>=0;i--){ if(D.taps[i]===0) zrun++; else break; }
  if(zrun>=2) alerts.push('<div class="alert red">🚨<div><b>No booking/phone taps recorded for '+zrun+' days.</b> At ~4 taps/day that\'s a &lt;1% event — GA4 tagging or the site is likely broken, not demand.</div></div>');
  /* 3. Hint feed staleness */
  const hint=srcState("hint");
  if(hint.cls==="stale") alerts.push('<div class="alert red">🚨<div><b>Hint members/consults feed is '+fmtAge(hint.ageH)+' old.</b> The 9:15am laptop poller (MBM-Dashboard-Members-Export) has missed runs — member and consult tiles are showing last-good values, hatched below.</div></div>');
  else if(hint.cls==="aging") alerts.push('<div class="alert amber">⏱<div><b>Hint feed aging ('+fmtAge(hint.ageH)+').</b> Poller may have missed this morning\'s run; values below are last-good.</div></div>');
  /* 3b. Unpaid concierge membership: live in Hint, not paying — real revenue leak */
  const _rec=SNAPSHOT.members.active_recon;
  if(_rec && +_rec.unpaid_concierge>0)
    alerts.push('<div class="alert amber">💳<div><b>'+fmtN(_rec.unpaid_concierge)+' Concierge membership'+(_rec.unpaid_concierge>1?'s are':' is')+' status "unpaid" in Hint</b> — an active patient not being billed (~$300/mo each). Not counted in the North Star. Check the membership\'s payment method in Hint. As of '+escapeHtml(_rec.as_of||'')+'.</div></div>');
  /* 4. Residual config risk */
  if(SNAPSHOT.gads.incident.residual) alerts.push('<div class="alert amber">⚠️<div><b>Ads goal config:</b> '+escapeHtml(SNAPSHOT.gads.incident.residual)+'</div></div>');
  /* 5. Meta delivery */
  if(SNAPSHOT.meta_ads.warn && SNAPSHOT.meta_ads.warn.indexOf("Not delivering")>=0)
    alerts.push('<div class="alert amber">⚠️<div><b>Meta:</b> the only active campaign is flagged <b>"Not delivering — Ad errors"</b> in Ads Manager. $'+SNAPSHOT.meta_ads.spend.toFixed(2)+' spent, frozen since '+escapeHtml(SNAPSHOT.meta_ads.window)+'. Fix or pause it.</div></div>');
  if(!alerts.length) alerts.push('<div class="alert green">✓<div>All sources reporting on schedule. No anomalies detected.</div></div>');
  document.getElementById("alerts").innerHTML=alerts.join("");
}

/* ---------- NORTH STAR ---------- */
function card(k,v,extra,staleCls,asof,hero){
  return '<div class="card'+(staleCls?' stale':'')+'"><div class="k">'+k+'</div><div class="v'+(hero?' hero':'')+'">'+v+'</div>'+(extra||"")+(asof?('<div class="asof">'+asof+'</div>'):'')+'</div>';
}
function renderNorthStar(){
  const period=selectedPeriod();
  setRangePill("nsRange", period);
  document.getElementById("nsNote").innerHTML="Goal: <b>300 active Concierge members</b>. Everything else on this page is a means to that number.";
  const act=getActive();
  const hint=srcState("hint");
  const ms=store.get("members_split:"+period,null)||{concierge:0,so:0};
  const mp=store.get("members_pending:"+period,null);
  const ch=store.get("consults_hint:"+period,null);
  const t=spendMTD(period);
  const newTot=(+ms.concierge||0)+(+ms.so||0);
  const cpm=newTot>0? t.spend/newTot : null;
  const cpc2=(ch&&ch.scheduled_mtd>0)? t.spend/ch.scheduled_mtd : ((ch&&ch.scheduled>0)? t.spend/ch.scheduled:null);

  let actHtml, actExtra="", actAsof="";
  if(act && act.concierge!=null){
    const pct=Math.min(100,(+act.concierge/SNAPSHOT.members.goal_concierge)*100);
    actHtml=fmtN(act.concierge)+' <small>of '+SNAPSHOT.members.goal_concierge+'</small>';
    actExtra='<div class="goalbar"><span style="width:'+pct+'%"></span></div>'+
      '<div class="small" style="margin-top:6px">'+Math.round(pct)+'% of goal · '+fmtN(act.so)+' Service-Only alongside</div>';
    var rec=SNAPSHOT.members.active_recon;
    if(rec && act.source==="hint"){
      var recBits=[];
      if(+rec.unpaid_concierge>0) recBits.push('<b style="color:var(--warn)">+'+fmtN(rec.unpaid_concierge)+' unpaid</b> (live in Hint, not paying — not counted)');
      if(+rec.pending_concierge>0) recBits.push('+'+fmtN(rec.pending_concierge)+' pending payment');
      if(+rec.comp_active>0) recBits.push(fmtN(rec.comp_active)+' comps/F&F excluded');
      if(+rec.test_active_excluded>0) recBits.push(fmtN(rec.test_active_excluded)+' test accts excluded');
      actExtra+='<div class="small" style="margin-top:4px;line-height:1.6">Hint badge reconciliation: '+(recBits.length?recBits.join(' · '):'clean')+' — plan badges count every status; this tile counts active paying patients only.</div>';
    }
    actAsof=(act.source==="hint"?"Hint feed":"manual entry")+" · as of "+escapeHtml(act.as_of||act.period);
  } else {
    actHtml='<span style="color:var(--stale)">—</span>';
    actExtra='<div class="small" style="margin-top:6px;line-height:1.6">Not wired yet: enter today\'s count in <b>Data Entry → Members</b> (one time). The Hint feed upgrade will take over automatically once the exporter update lands.</div>';
  }
  const schEl=(ch&&(ch.scheduled_mtd!=null||ch.scheduled!=null))?(ch.scheduled_mtd!=null?ch.scheduled_mtd:ch.scheduled):null;
  const compEl=(ch&&(ch.completed_mtd!=null||ch.completed!=null))?(ch.completed_mtd!=null?ch.completed_mtd:ch.completed):null;
  document.getElementById("northstar").innerHTML =
    card("Active Concierge members", actHtml, actExtra, false, actAsof, true) +
    card("New members — "+periodShort(period), fmtN(newTot)+' <small>('+fmtN(ms.concierge)+'C / '+fmtN(ms.so)+'SO)</small>',
      ((mp&&mp.total)?'<div class="small" style="margin-top:6px">+ '+fmtN(mp.total)+' pending payment ('+fmtN(mp.concierge)+'C/'+fmtN(mp.so)+'SO)</div>':'')+
      '<div class="small" style="margin-top:4px">'+escapeHtml(SNAPSHOT.members.basis)+'</div>'+smallN(),
      hint.cls==="stale", "Hint · "+fmtAge(hint.ageH)) +
    card("Booked consults — "+periodShort(period), fmtN(schEl),
      '<div class="small" style="margin-top:6px">'+fmtN(compEl)+' completed · '+fmtN(ch?ch.upcoming:null)+' upcoming</div><div class="small" style="margin-top:4px">the leading indicator — predicts joins ~4–8 weeks out</div>'+smallN(),
      hint.cls==="stale", "Hint · "+fmtAge(hint.ageH)) +
    card("Cost per new member", fmtUSD(cpm),
      '<div class="small" style="margin-top:6px">'+escapeHtml(t.note)+' ÷ all new members (blended)</div><div class="small" style="margin-top:4px">cost per booked consult: <b>'+fmtUSD(cpc2)+'</b></div>'+smallN(),
      false, "computed · spend "+fmtUSD(t.spend));
}
