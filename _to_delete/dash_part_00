  .card{background:var(--card);border:1px solid var(--line);border-radius:14px;padding:16px 17px;position:relative;box-shadow:var(--shadow-1);transition:box-shadow .18s ease,transform .18s ease}
  .card:hover{box-shadow:var(--shadow-2);transform:translateY(-1px)}
  .card .k{font-family:var(--label);font-size:11px;letter-spacing:.07em;text-transform:uppercase;color:var(--muted)}
  .card .v{font-family:var(--label);font-weight:650;font-size:28px;color:var(--forest);margin-top:6px;letter-spacing:-.4px}
