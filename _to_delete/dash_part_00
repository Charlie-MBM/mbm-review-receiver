    <div class="grid3" style="margin-top:14px">
      <div class="panel">
        <div class="small" style="margin-bottom:10px">Tracked-keyword distribution</div>
        <div style="display:flex;gap:18px;align-items:baseline">
          <div><div class="v" style="font-family:var(--label);font-weight:600;font-size:24px;color:var(--forest)" id="kwTop3">—</div><div class="small">TOP 3</div></div>
          <div><div class="v" style="font-family:var(--label);font-weight:600;font-size:24px;color:var(--forest)" id="kwTop10">—</div><div class="small">TOP 10</div></div>
          <div><div class="v" style="font-family:var(--label);font-weight:600;font-size:24px;color:var(--forest)" id="kwTotal">—</div><div class="small">RANKING</div></div>
