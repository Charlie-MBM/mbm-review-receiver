function projectMonth(cur){
  if(!cur || !(+cur.days_counted>0) || !(+cur.days_in_month>0)) return null;
  const f=(+cur.days_in_month)/(+cur.days_counted);
  return { month:cur.month, factor:f, through:cur.through,
    days_counted:+cur.days_counted, days_in_month:+cur.days_in_month,
    clicks:Math.round((+cur.clicks||0)*f), impressions:Math.round((+cur.impressions||0)*f),
    mtd_clicks:+cur.clicks||0, mtd_impressions:+cur.impressions||0,
    ctr:(cur.ctr==null?null:+cur.ctr), position:(cur.position==null?null:+cur.position),
    impressions_rounded:!!cur.impressions_rounded };
}
function renderProjNote(proj, lastActual){
  const el=document.getElementById("gscProjNote"); if(!el) return;
  if(!proj){ el.innerHTML=""; return; }
  const dpct=(a,b)=>(b>0?Math.round(((a-b)/b)*1000)/10:null);
  const cD=dpct(proj.clicks,lastActual.clicks), iD=dpct(proj.impressions,lastActual.impressions);
  const arrow=v=>v==null?"":(v>0?'<b style="color:var(--good)">▲'+v+'%</b>':(v<0?'<b style="color:var(--bad)">▼'+Math.abs(v)+'%</b>':'<b>flat</b>'));
  const posBetter=(proj.position!=null&&lastActual.position!=null)?(proj.position<lastActual.position):null;
  el.innerHTML =
    '<b>'+proj.month+' projection (dashed):</b> '+fmtN(proj.mtd_clicks)+' clicks / '+fmtN(proj.mtd_impressions)+
    ' impressions banked over <b>'+proj.days_counted+' settled days</b> ('+proj.through+
    '), scaled ×'+(Math.round(proj.factor*100)/100)+' to a '+proj.days_in_month+'-day month → <b>~'+fmtN(proj.clicks)+
    ' clicks</b> '+arrow(cD)+' and <b>~'+fmtN(proj.impressions)+' impressions</b> '+arrow(iD)+' vs '+lastActual.date+'.<br>'+
    '<b>CTR ('+fmtPct(proj.ctr)+') and average position ('+fmtPos(proj.position)+') are month-to-date actuals, deliberately NOT scaled</b> — they are rates; scaling a rate fabricates a number the site never hit'+
    (posBetter===false?' — and position is currently <b style="color:var(--bad)">worse</b>, so reach is growing faster than rank.':'.')+'<br>'+
    '<span style="font-style:italic">Straight-line extrapolation front-loads any spike; GSC finalises 2–3 days late so only settled days count'+
    (proj.impressions_rounded?'; impressions from GSC UI round to 3 significant figures (±~50)':'')+'.</span>';
}
