    if(ev==="booking_click"){ f.book+=c; src.inquiries[b]+=c; }
  });
  // handoffs: outbound clicks to the Hint booking domain, MTD
  const body2={ dateRanges:[{startDate:monthStartISO(),endDate:"today"}],
    dimensions:[{name:"linkDomain"}], metrics:[{name:"eventCount"},{name:"totalUsers"}],
    dimensionFilter:{filter:{fieldName:"eventName",stringFilter:{value:"click"}}}, limit:50 };
  const res2=await window.cowork.callMcpTool(ZAPIER,{ selected_api:"GoogleAnalytics4CLIAPI", action:"_zap_raw_request",
    instructions:"GA4 runReport: MTD outbound clicks by link domain with unique users.",
    params:{ url:"https://analyticsdata.googleapis.com/v1beta/"+GA4.property+":runReport", method:"POST", fail_on_errors:"true", body:JSON.stringify(body2) },
    output:"linkDomain, eventCount, totalUsers rows"});
  const d2=unwrap(res2); const rows2=(d2&&(d2.results||d2.rows))||[];
  if(!rows2.length) throw new Error("GA4 linkDomain query returned 0 rows — raw: "+snip(d2!=null?d2:res2));
  let handoffs=0, handoffUsers=0;
  rows2.forEach(r=>{ const ld=String(r.link_domain||r.linkDomain||""); if(ld==="mtbakermedical.hint.com"){ handoffs+=parseInt(r.event_count||r.eventCount||0,10)||0; handoffUsers+=parseInt(r.total_users||r.totalUsers||0,10)||0; } });
  // deduped unique tappers (booking+phone, one row, no dimension = users who did both count once)
  const body3={ dateRanges:[{startDate:monthStartISO(),endDate:"today"}],
    metrics:[{name:"totalUsers"}],
    dimensionFilter:{filter:{fieldName:"eventName",inListFilter:{values:["booking_click","phone_click"]}}}, limit:5 };
  const res3=await window.cowork.callMcpTool(ZAPIER,{ selected_api:"GoogleAnalytics4CLIAPI", action:"_zap_raw_request",
    instructions:"GA4 runReport: MTD deduplicated unique users across booking_click + phone_click.",
    params:{ url:"https://analyticsdata.googleapis.com/v1beta/"+GA4.property+":runReport", method:"POST", fail_on_errors:"true", body:JSON.stringify(body3) },
    output:"single totalUsers value"});
  const d3=unwrap(res3); const row3=(d3&&(d3.results||d3.rows))||[];
  const tappers=(function(){ const r=Array.isArray(row3)?row3[0]:row3; return r?(parseInt(r.total_users||r.totalUsers||0,10)||0):((d3&&+d3.totalUsers)||0); })();
  const per=curPeriod();
  store.set("funnel:"+per, Object.assign(getFunnel(per), {site_visits:f.visits, inq_booking:f.book, inq_phone:f.phone, handoffs:handoffs}));
  store.set("funnel_src:"+per, src);
  if(tappers>0) store.set("funnel_users:"+per, {tappers:tappers, handoff:handoffUsers, as_of:todayISO(),
    note:"GA4 totalUsers = unique browsers/devices"});
  markOk("ga4");
}
async function refreshAds(){
  if(!(window.cowork && window.cowork.callMcpTool)) throw new Error("MCP bridge unavailable");
  const q="SELECT campaign.name, metrics.cost_micros, metrics.impressions, metrics.clicks, metrics.conversions FROM campaign WHERE segments.date BETWEEN '"+monthStartISO()+"' AND '"+todayISO()+"'";
  const res=await window.cowork.callMcpTool(ZAPIER,{ selected_api:"GoogleAdsCLIAPI", action:"_zap_raw_request",
    instructions:"Google Ads GAQL v21: campaign performance, true month-to-date.",
    params:{ url:"https://googleads.googleapis.com/v21/customers/"+GADS_ACCOUNT+"/googleAds:searchStream", method:"POST", fail_on_errors:"true", body:JSON.stringify({query:q}) },
    output:"per-campaign cost, impressions, clicks, conversions"});
  const data=unwrap(res); const rows=(data&&(data.results||data.rows))||[];
  if(!rows.length) throw new Error("Ads returned 0 rows — raw: "+snip(data!=null?data:res));
  let spend=0,impr=0,clk=0,conv=0;
  rows.forEach(r=>{ const cst=(r.cost_micros!=null)?(+r.cost_micros||0)/1e6:(+r.cost||0); spend+=cst; impr+=+r.impressions||0; clk+=+r.clicks||0; conv+=+r.conversions||0; });
  const per=curPeriod();
  const prev=store.get("ads:"+per+":google",{});
  store.set("ads:"+per+":google", {spend:Math.round(spend*100)/100, impressions:impr, clicks:clk, conversions:(prev.conversions!=null?prev.conversions:conv)});
  markOk("gads");
}
async function refreshAhrefs(){
  if(!(window.cowork && window.cowork.callMcpTool)) throw new Error("MCP bridge unavailable");
  const pid=parseInt(cfg().project_id,10); if(!pid) throw new Error("no Ahrefs project id");
  const r=await window.cowork.callMcpTool(AHREFS+"rank-tracker-overview",{project_id:pid,date:todayISO(),device:"mobile",select:"keyword,position,keyword_difficulty,volume,url",limit:1000});
  const data=unwrap(r); const ov=(data&&data.overviews)||[];
  if(!ov.length) throw new Error("Rank Tracker returned 0 rows (units exhausted or no snapshot for today) — raw: "+snip(data!=null?data:r));
  const prev=store.get("kw_live",{})||{};
  const live={};
  ov.forEach(o=>{ const k=o.keyword; const prevPos=(prev[k]&&prev[k].p!=null)?prev[k].p:(KW[k]?KW[k].p:null);
    let d=null; if(o.position!=null&&prevPos!=null) d=prevPos-o.position;
    live[k]={p:o.position, kd:o.keyword_difficulty, v:o.volume, d:d, url:o.url}; });
  store.set("kw_live", live); store.set("kw_live_date", todayISO());
  markOk("ahrefs");
}
async function refreshAllLive(){
  const btn=document.getElementById("refreshBtn");
  if(btn){ btn.disabled=true; btn.textContent="↻ refreshing…"; }
  const jobs=[["ga4",refreshGA4],["gads",refreshAds],["ahrefs",refreshAhrefs]];
  for(const [k,fn] of jobs){
    try{ await withRetry(fn,2); }
    catch(e){ markErr(k,e); }
  }
  if(btn){ btn.disabled=false; btn.textContent="↻ Refresh live"; }
  refreshAll();
}

