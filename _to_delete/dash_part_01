/* ---------- WIRING ---------- */
function buildPeriodPicker(){
  const ps=document.getElementById("periodSel"); const prevVal=ps.value;
  const periods=recentPeriods(18);
  ps.innerHTML=periods.map(p=>'<option value="'+p+'">'+p+'</option>').join("");
  if(prevVal && periods.indexOf(prevVal)>=0) ps.value=prevVal; else ps.value=curPeriod();
}
function renderFinance(){
  const F=SNAPSHOT.finance; if(!F) return;
  const el=document.getElementById("finance"); if(!el) return;
  setRangePill("finRange", F.month);
  const qb=srcState("qb"), hint=srcState("hint");
  const rev=(F.revenue&&F.revenue.mtd!=null)?+F.revenue.mtd:null;
  const cost=(F.costs&&F.costs.mtd!=null)?+F.costs.mtd:null;
  const net=(rev!=null&&cost!=null)?(rev-cost):null;
  const dash='<span style="color:var(--stale)">—</span>';
  let cards="";
  cards+=card("Revenue — collected (MTD)", rev!=null?fmtUSD(rev):dash,
    '<div class="small" style="margin-top:6px;line-height:1.6">'+escapeHtml(F.revenue.basis)+
    (rev==null?'<br><b>Not wired yet:</b> lands with the next Hint feed run (exporter v4 revenue pull).':'')+'</div>',
    false, rev!=null?("Hint · as of "+escapeHtml(F.revenue.as_of||"")):"awaiting first pull");
  cards+=card("Costs — booked (MTD)", cost!=null?fmtUSD(cost):dash,
    '<div class="small" style="margin-top:6px;line-height:1.6">'+escapeHtml(F.costs.basis)+
    (cost==null?'<br><b>Not wired yet:</b> reconnect the QuickBooks connector, then the daily task pulls P&L expenses.':'')+'</div>',
    qb&&qb.cls==="stale"&&cost!=null, cost!=null?("QuickBooks · as of "+escapeHtml(F.costs.as_of||"")):"awaiting QuickBooks re-auth");
  cards+=card("Net (MTD)", net!=null?('<span style="color:'+(net>=0?'var(--good)':'var(--bad)')+'">'+fmtUSD(net)+'</span>'):dash,
    '<div class="small" style="margin-top:6px;line-height:1.6">'+(net!=null?('margin '+(rev>0?Math.round(net/rev*100)+'%':'—')+' · '):'')+escapeHtml(F.caveat)+'</div>',
    false, net!=null?"computed":"needs both sides wired", true);
  el.innerHTML=cards;
}
function renderLeadMagnet(){
  const K=SNAPSHOT.kit; const el=document.getElementById("leadMagnet"); if(!el||!K) return;
