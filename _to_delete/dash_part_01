      fieldNum("Consults booked","fn_consults",ff.consults)+
      fieldNum("New members","fn_members",ff.new_members)+
      '</div><div style="margin-top:12px"><button class="btn" id="saveFunnel">Save funnel</button></div>';
    document.getElementById("saveFunnel").onclick=()=>{ store.set("funnel:"+period,Object.assign(getFunnel(period),{site_visits:num("fn_visits"),inq_booking:num("fn_book"),inq_phone:num("fn_phone"),handoffs:num("fn_hand"),consults:num("fn_consults"),new_members:num("fn_members")})); refreshAll(); };
  } else if(activeTab==="settings"){
    const c=cfg();
    body.innerHTML='<div class="formgrid" style="grid-template-columns:repeat(auto-fit,minmax(200px,1fr))">'+
