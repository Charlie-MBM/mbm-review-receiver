function refreshAll(){ renderStatus(); renderFinance(); renderLeadMagnet(); renderNorthStar(); renderFunnel(); renderMemberSource(); renderPaid(); renderGBP(); renderSEO(); renderEntry(); }
function init(){
  buildPeriodPicker();
  document.getElementById("periodSel").onchange=refreshAll;
  document.getElementById("refreshBtn").onclick=()=>refreshAllLive();
  document.querySelectorAll("#entryTabs .tab").forEach(t=>{ t.onclick=()=>{ document.querySelectorAll("#entryTabs .tab").forEach(x=>x.classList.remove("active")); t.classList.add("active"); activeTab=t.dataset.tab; renderEntry(); }; });
  document.getElementById("foot").innerHTML='Every tile carries its source and as-of date; hatched tiles are serving last-good (stale) values. Baked snapshot '+escapeHtml(SNAPSHOT.baked_at)+' · data version '+escapeHtml(DATA_VERSION)+'. Definitions &amp; refresh contract: <b>mbm-review-receiver/DASHBOARD_METRICS.md</b>. Windows are true month-to-date unless a tile says otherwise. Trend arrows are deliberately absent from small counts — a one-member swing is 33% noise, not a trend.';
  seedRealData();
  refreshAll();
}
function boot(){
  try{ init(); }
  catch(e){
    var b=document.createElement('div');
    b.style.cssText='font-family:monospace;font-size:12px;background:#fbeeea;color:#b4452f;padding:14px;margin:14px;border:1px solid #b4452f;border-radius:8px;white-space:pre-wrap';
    b.textContent='Dashboard error (please send this to Claude):\n'+(e&&e.message||e)+'\n\n'+(e&&e.stack||'');
    if(document.body) document.body.insertBefore(b, document.body.firstChild);
  }
}
if(document.readyState==="loading") document.addEventListener("DOMContentLoaded",boot); else boot();
