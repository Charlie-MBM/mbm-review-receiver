    document.getElementById("saveAds").onclick=()=>{ PLATFORMS.forEach(p=>{ store.set("ads:"+period+":"+p,{spend:num("ad_"+p+"_spend"),impressions:num("ad_"+p+"_impressions"),clicks:num("ad_"+p+"_clicks"),conversions:num("ad_"+p+"_conversions")}); }); refreshAll(); };
  } else if(activeTab==="funnel"){
