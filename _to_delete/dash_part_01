/* ---------- LIVE REFRESH (optional; the daily task re-bakes SNAPSHOT) ----------
   Every pull surfaces its result. Success updates src_asof:<k>; failure sets
   src_err:<k> and the chip turns red. NOTHING falls back silently. */
function unwrap(res){
  if(res==null) return null;
  if(typeof res==="object" && !Array.isArray(res) && !res.content) return res;
  try{ if(res.content && res.content.length){ const t=res.content.map(x=>x.text||"").join(""); return JSON.parse(t); } }catch(e){}
  if(typeof res==="string"){ try{return JSON.parse(res);}catch(e){return null;} }
  return res;
}
function todayISO(){ return new Date().toISOString().slice(0,10); }
function monthStartISO(){ const d=new Date(); return d.getFullYear()+"-"+pad(d.getMonth()+1)+"-01"; }
async function withRetry(fn, tries){
  let lastErr=null; const T=tries||2;
  for(let i=0;i<T;i++){
    try{ return await fn(); }
    catch(e){ lastErr=e; if(i<T-1) await new Promise(r=>setTimeout(r, 1200*(i+1))); }
  }
  throw lastErr;
}
function markOk(k){ store.set("src_asof:"+k, new Date().toISOString()); store.del("src_err:"+k); }
function markErr(k,e){ store.set("src_err:"+k, String(e&&e.message||e).slice(0,320)); }
function snip(o){ try{ return JSON.stringify(o).slice(0,200); }catch(e){ return String(o).slice(0,200); } }

async function refreshGA4(){
