    output:"channel, event, eventCount rows"});
  const data=unwrap(res); const rows=(data&&(data.results||data.rows))||[];
  if(!rows.length) throw new Error("GA4 returned 0 rows — raw: "+snip(data!=null?data:res));
  const f={visits:0,book:0,phone:0};
  const src={visits:{organic:0,direct:0,google:0,meta:0,other:0}, inquiries:{organic:0,direct:0,google:0,meta:0,other:0}};
  rows.forEach(r=>{
