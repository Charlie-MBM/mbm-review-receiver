function srcSegs(split, colors){
  let segs=''; let tot=0;
  colors.forEach(function(c){ tot+=+(split&&split[c[0]])||0; });
  colors.forEach(function(c){ const v=+(split&&split[c[0]])||0; if(v>0) segs+='<span style="flex:'+v+';background:'+c[1]+'" title="'+(c[2]||c[0])+': '+v+'"></span>'; });
  if(tot<=0) segs='<span style="flex:1;background:#d3dcd5"></span>';
  return segs;
}
function fbar(val, w, split, colors, sub){
  const txt=fmtN(val)+(sub?' <span style="font-weight:400;opacity:.85;font-size:10.5px;margin-left:3px">'+sub+'</span>':'');
  /* Labels never clip: a narrow bar can't fit its label inside (overflow:hidden
     chops it into a jumble), so below 40% width the label renders OUTSIDE the
     bar end in ink. Wide bars keep the in-bar white label. */
  const narrow = w < 40;
  if(split && colors){
    if(narrow) return '<div class="fbar fbar-split" style="width:'+w+'%">'+srcSegs(split,colors)+'</div><span class="fnum-out">'+txt+'</span>';
    return '<div class="fbar fbar-split" style="width:'+w+'%"><span class="fnum">'+txt+'</span>'+srcSegs(split,colors)+'</div>';
  }
  if(narrow) return '<div class="fbar" style="width:'+w+'%"></div><span class="fnum-out">'+txt+'</span>';
  return '<div class="fbar" style="width:'+w+'%">'+txt+'</div>';
}
